<div id="<%= dom_id article %>">
  <p>
    <strong>Title:</strong>
    <%= article.title %>
  </p>

  <p>
    <strong>Body:</strong>
    <%= article.body %>
  </p>

  <p>
    <strong>Cover:</strong>
    <%= image_tag article.cover_image.variant(:thumb) if article.cover_image.attached? %>
  </p>

  <p>
    <strong>Date:</strong>
    <%= l(article.created_at, format: :only_date) %>
  </p>

</div>
